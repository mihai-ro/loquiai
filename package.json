{
  "name": "@mihairo/loqui",
  "version": "2.2.2",
  "type": "module",
  "description": "loqui — i18n translation engine for software projects.",
  "repository": {
    "url": "https://github.com/mihai-ro/loquiai"
  },
  "keywords": [
    "i18n",
    "translation",
    "language",
    "locale",
    "ai"
  ],
  "author": {
    "name": "Mihai Ro"
  },
  "license": "Apache-2.0",
  "exports": {
    ".": {
      "import": "./dist/lib.js",
      "require": "./dist/lib.cjs"
    },
    "./cli": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/lib.cjs",
  "module": "./dist/lib.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "loqui": "dist/index.js"
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json && node scripts/build.mjs",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "test": "tsc -p tsconfig.test.json && node --test .dist-test/*.test.js .dist-test/engines/*.test.js .dist-test/utils/*.test.js",
    "test:ci": "tsc -p tsconfig.test.json && node --test --test-reporter=spec --test-reporter-destination=stdout --test-reporter=junit --test-reporter-destination=test-results.xml .dist-test/*.test.js .dist-test/engines/*.test.js .dist-test/utils/*.test.js",
    "test:coverage": "tsc -p tsconfig.test.json && c8 --check-coverage node --test .dist-test/*.test.js .dist-test/engines/*.test.js .dist-test/utils/*.test.js",
    "test:watch": "node --test --watch .dist-test/*.test.js .dist-test/engines/*.test.js .dist-test/utils/*.test.js",
    "clean": "rm -rf dist",
    "lint": "biome check src/",
    "lint:fix": "biome check --fix src/",
    "format": "biome format src/",
    "format:fix": "biome format --write src/",
    "prepublishOnly": "pnpm test:ci && pnpm clean && pnpm build",
    "translate": "node dist/index.js"
  },
  "files": [
    "dist",
    ".loqui.example.json",
    "loqui.schema.json",
    "README.md"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^22.0.0",
    "c8": "^11.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^7.0.2"
  },
  "packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25"
}
